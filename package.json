{
  "name": "@theclawlab/pai",
  "type": "module",
  "version": "2.1.0",
  "description": "pai is a linux command to interact with LLMs (with only one bash_exec tool and basic session support).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "pai": "./dist/cli.js"
  },
  "scripts": {
    "dev-old": "tsx watch src/index.ts",
    "dev": "tsup --watch --onSuccess 'node dist/index.js'",
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "release:local": "npm run build && npm link",
    "release:public": "npm test && npm run build && npm publish --access public",
    "release:public:skip-test": "npm run build && npm publish --access public"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "README.md",
    "USAGE.md"
  ],
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.1.2",
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.57.1",
    "commander": "^14.0.3"
  }
}
